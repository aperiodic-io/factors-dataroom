# Required: Your Aperiodic Factors API key
APERIODIC_API_KEY=your_api_key_here

# Optional: Override the API base URL (defaults to https://factors.aperiodic.io)
# APERIODIC_BASE_URL=https://factors.aperiodic.io

# Optional: Cloudflare Access service token (required when APERIODIC_BASE_URL
# points to an Access-protected environment)
# CF_ACCESS_CLIENT_ID=your_client_id_here
# CF_ACCESS_CLIENT_SECRET=your_client_secret_here
